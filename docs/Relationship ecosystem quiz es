        ${unlockStrip}
        <div class="mmc-brand-row">
          <div class="mmc-word">Mobius<span> Mesh</span></div>
        </div>
      </div>
    </div>`;
}

function showResults(){
  // Result tier box — neutral preview only.
  // Headline is pulled directly from Soleil's own INTERPRETATIONS text for whichever
  // dimension scored highest, never composed/extrapolated. Value framing (good/bad)
  // is only applied for Unmet Needs, Mental Health Load, and the consent/abuse flags —
  // every other dimension is presented descriptively, with no judgment on score level.
  const sortedDims=[...SECTIONS].sort((a,b)=>(scores[b.id]||0)-(scores[a.id]||0));
  const topDim=sortedDims[0];
  const topScore=scores[topDim.id]||0;
  const headline=getInterp(topDim.id,topScore);
  const previewNames=sortedDims.slice(0,3).map(d=>d.label).join(' · ');
  document.getElementById('result-tier-box').innerHTML=`
    <div class="result-tier" style="background:rgba(26,20,16,0.03);border-color:rgba(26,20,16,0.12)">
      <div class="eyebrow">Tus áreas con puntaje más alto<\/div>
      <h2 style="margin-bottom:8px">${previewNames}<\/h2>
      <p class="sub" style="margin-bottom:12px">${headline}<\/p>
    <\/div>`;

  renderMeshCard({allUnlocked:false});

  // Consent education module — shown whenever Q6 (shame-on-rejection) or
  // Q7 (pushback-on-rejection) is any non-zero value. This is informational
  // and empathetic — not a verdict. Content in Soleil's own voice.
  const shameScore=scores._shame_rejection||0;
  const pushbackScore=scores._pushback_rejection||0;
  const consentModuleEl=document.getElementById('consent-module');
  if(consentModuleEl){
    if(shameScore>0||pushbackScore>0){
      consentModuleEl.style.display='block';
    } else {
      consentModuleEl.style.display='none';
    }
  }

  // Radar — letter markers (A–I) instead of inline text labels, which clipped/overlapped
  // at this density. A legend below the chart spells out the key.
  const svg=document.getElementById('radar-svg');
  const cx=230,cy=230,r=165,n=SECTIONS.length;
  const letters=['A','B','C','D','E','F','G','H','I'];
  const angles=SECTIONS.map((_,i)=>(i/n)*Math.PI*2-Math.PI/2);
  const getPoint=(a,v)=>({x:cx+Math.cos(a)*r*v,y:cy+Math.sin(a)*r*v});
  let svgHtml='';
  [.25,.5,.75,1].forEach(lv=>{
    const pts=angles.map(a=>getPoint(a,lv));
    svgHtml+=`<path d="${pts.map((p,i)=>`${i===0?'M':'L'}${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ')} Z" fill="none" stroke="rgba(26,20,16,0.07)" stroke-width="1"/>`;
  });
  angles.forEach((a,i)=>{const e=getPoint(a,1);svgHtml+=`<line x1="${cx}" y1="${cy}" x2="${e.x.toFixed(1)}" y2="${e.y.toFixed(1)}" stroke="rgba(26,20,16,0.07)" stroke-width="1"/>`;});
  const dataPoints=SECTIONS.map((sec,i)=>getPoint(angles[i],scores[sec.id]||0));
  svgHtml+=`<path d="${dataPoints.map((p,i)=>`${i===0?'M':'L'}${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ')} Z" fill="rgba(139,69,19,0.12)" stroke="rgba(139,69,19,0.7)" stroke-width="2"/>`;
  SECTIONS.forEach((sec,i)=>{
    const score=scores[sec.id]||0;
    const pt=getPoint(angles[i],score);
    const lp=getPoint(angles[i],1.22);
    svgHtml+=`<circle cx="${pt.x.toFixed(1)}" cy="${pt.y.toFixed(1)}" r="5" fill="${sec.color}"/>`;
    svgHtml+=`<circle cx="${lp.x.toFixed(1)}" cy="${lp.y.toFixed(1)}" r="13" fill="${sec.color}" opacity="0.15"/>`;
    svgHtml+=`<text x="${lp.x.toFixed(1)}" y="${lp.y.toFixed(1)}" text-anchor="middle" dominant-baseline="central" font-size="17" font-weight="600" fill="${sec.color}">${letters[i]}<\/text>`;
  });
  svg.innerHTML=svgHtml;

  // Legend — letter key below the chart
  const legendHtml=SECTIONS.map((sec,i)=>
    `<span style="display:inline-flex;align-items:center;gap:6px;margin-right:16px;margin-bottom:6px">
       <span style="display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;background:${sec.color};color:#fff;font-size:11px;font-weight:600">${letters[i]}<\/span>
       <span style="font-size:10.5px;color:var(--muted)">${sec.label}<\/span>
     <\/span>`
  ).join('');
  const legendEl=document.getElementById('radar-legend');
  if(legendEl) legendEl.innerHTML=legendHtml;

  // Dimension cards with skill preview
  let cardsHtml='';
  SECTIONS.forEach(sec=>{
    const score=scores[sec.id]||0;
    const pct=Math.round(score*100);
    const interp=getInterp(sec.id,score);
    const map=SKILL_MAP[sec.id];
    const skillPills=map.skills.map((s,i)=>`<span class="skill-pill" style="background:${map.colors[i]}">${s}<\/span>`).join('');
    cardsHtml+=`<div class="dim-card"><div class="dim-card-accent" style="background:${sec.color}"><\/div><div class="dim-card-label" style="color:${sec.color}">${sec.label}<\/div><div class="dim-card-bar"><div class="dim-card-fill" style="width:${pct}%;background:${sec.color}"><\/div><\/div><div class="dim-card-score">${(score*5).toFixed(1)} / 5<\/div><div class="dim-card-interp">${interp}<\/div><div class="skills-preview">${skillPills}<\/div><\/div>`;
  });
  document.getElementById('results-cards').innerHTML=cardsHtml;

  // Pathways — only links to destinations that currently exist.
  // Book a Session, Substack, and the free pathway cards (Ethical AI Suite, Human Relating Plan)
  // were removed since those pages/tools don't exist yet. Their copy is preserved in
  // project notes for reuse once those destinations are live.
  document.getElementById('pathways-section').innerHTML=`
    <div style="margin-bottom:12px"><div class="eyebrow">Próximos pasos<\/div><\/div>
    <div class="pathway-box" style="border-color:rgba(139,69,19,0.3);background:rgba(139,69,19,0.04)">
      <h3 style="color:#8B4513">Análisis Completo<\/h3>
      <p>El desglose personalizado completo de las 9 dimensiones, recomendaciones de tipo de relación, y estrategias para avanzar. <a href="https://buy.stripe.com/4gM6oJfmQaMcafmgtQ57W00">Obtén el análisis completo ($20) →<\/a><\/p>
    <\/div>
    <div class="pathway-box" style="border-color:rgba(255,45,120,0.3);background:rgba(255,45,120,0.04)">
      <h3 style="color:#C04878">Mazo de Habilidades<\/h3>
      <p>Dieciséis cartas de habilidades relacionales mapeadas a estas dimensiones — qué son, por qué importan, y cómo construirlas. <a href="https://soleilmerroir.com/skill-deck">Explora el mazo de habilidades →<\/a><\/p>
    <\/div>`;

  buildEcosystemViz();
  showScreen('results');
  window.scrollTo(0,0);
}


function gateSubmit(){
  var name = document.getElementById('gate-name').value.trim();
  var email = document.getElementById('gate-email').value.trim();
  if(!name || !email){ alert('Por favor ingresa tu nombre y correo electrónico para ver tus resultados.'); return; }
  // Populate the original name/email fields for submitEmail
  document.getElementById('result-name').value = name;
  document.getElementById('result-email').value = email;
  submitEmail();
}

function submitEmail(){
  const email=document.getElementById('result-email').value.trim();
  const name=document.getElementById('result-name').value.trim();
  if(!email||!email.includes('@')){document.getElementById('result-email').focus();return;}
  const scoresSummary=SECTIONS.map(sec=>({dimension:sec.label,score:+(scores[sec.id]*5).toFixed(1),interpretation:getInterp(sec.id,scores[sec.id])}));
  const payload={
    name:name||'amiga/o', email, language:'es',
    scores:scoresSummary, raw_scores:scores,
    needs_score:+((scores.needs||0)*5).toFixed(1),
    mentalhealth_score:+((scores.mentalhealth||0)*5).toFixed(1),
    identity_score:+((scores.identity||0)*5).toFixed(1),
    erotic_score:+((scores.erotic||0)*5).toFixed(1),
    relational_score:+((scores.relational||0)*5).toFixed(1),
    emotional_score:+((scores.emotional||0)*5).toFixed(1),
    somatic_score:+((scores.somatic||0)*5).toFixed(1),
    neurodivergence_score:+((scores.neurodivergence||0)*5).toFixed(1),
    digital_score:+((scores.digital||0)*5).toFixed(1),
    consent_difficulty:+(answers[5]||0),
    shame_on_rejection:+(answers[6]||0),
    pushback_on_rejection:+(answers[7]||0),
    consent_module_triggered:((answers[6]||0)>0||(answers[7]||0)>0),
    referral_code:referralCode||null,
    referral_tier:referralTier||null,
    quickchart_url:buildQuickChartURL(),
    skill_deck_url:'https://soleilmerroir.com/skill-deck',
    workbook_url:'https://buy.stripe.com/4gM6oJfmQaMcafmgtQ57W00',
    timestamp:new Date().toISOString()
  };
  const WEBHOOK_URL='https://hook.us2.make.com/6xrwfh7vvdqw329wm5u0mhe7l7v39kx9';
  fetch(WEBHOOK_URL,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}).catch(()=>{});
  showResults();showScreen('results');window.scrollTo(0,0);
}

function showScreen(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById('screen-'+id).classList.add('active');}
function retakeQuiz(){answers={};scores={};currentSection=0;showScreen('quiz');renderSection();}

</script>
