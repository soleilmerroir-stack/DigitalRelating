  document.getElementById('progress-fill').style.width=pct+'%';
  document.getElementById('progress-label').textContent=`Sección ${currentSection+1} de ${SECTIONS.length} — ${sec.label}`;
  document.getElementById('q-count').textContent=`P${doneQ+1}–${doneQ+sec.questions.length} de ${totalQ}`;
  document.getElementById('btn-back').style.display=currentSection>0?'inline-block':'none';
  document.getElementById('btn-next').textContent=currentSection===SECTIONS.length-1?'Ver mis resultados →':'Siguiente →';
  let html=`<div class="section-header" style="border-left-color:${sec.color};background:${sec.accent}"><h2 style="color:${sec.color}">${sec.label}<\/h2><p>${sec.desc}<\/p><\/div>`;
