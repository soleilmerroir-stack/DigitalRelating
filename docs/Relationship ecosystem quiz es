function nextSection(){
  const sec=SECTIONS[currentSection];
  const missing=sec.questions.filter(q=>answers[q.n]===undefined);
  if(missing.length>0){
    const el=document.querySelector(`[data-q="${missing[0].n}"]`);
    if(el){el.closest('.question').scrollIntoView({behavior:'smooth',block:'center'});el.closest('.question').style.outline='2px solid #B85020';setTimeout(()=>el.closest('.question').style.outline='',2000);}
    return;
  }
  if(currentSection<SECTIONS.length-1){currentSection++;renderSection();}
  else{computeScores();showScreen('email');window.scrollTo(0,0);}
}

function prevSection(){if(currentSection>0){currentSection--;renderSection();}}

function computeScores(){
  scores={};
  SECTIONS.forEach(sec=>{
    // Flagged questions (Q5/Q6/Q7 — consent/SGBV screening) are displayed and sent to
    // the webhook but excluded from dimension averages — they're clinical flags, not
    // traits to score. Q6/Q7 > 0 triggers the consent education module in showResults().
    const scored=sec.questions.filter(q=>!q.flag);
    const vals=scored.map(q=>{let v=(answers[q.n]||0)/5;if(q.invert)v=1-v;return v;});
    scores[sec.id]=vals.length?vals.reduce((a,b)=>a+b,0)/vals.length:0;
  });
  // Keep suicidal-ideation safety flag lookup for crisis routing — this is
  // not a severity bucket, it's a specific safety check with its own module.
  let siQ=null;
  for(const sec of SECTIONS){ const f=sec.questions.find(q=>q.safety); if(f){siQ=f;break;} }
  scores._si=siQ?(answers[siQ.n]||0)/5:0;
  // Consent/pushback flag scores — any non-zero value triggers education module
  scores._shame_rejection=(answers[6]||0)/5;
  scores._pushback_rejection=(answers[7]||0)/5;
}

function getInterp(id,score){
  for(const[lo,hi,text]of INTERPRETATIONS[id]){if(score>=lo&&score<=hi)return text;}
  return INTERPRETATIONS[id][INTERPRETATIONS[id].length-1][2];
}

