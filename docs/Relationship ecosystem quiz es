function buildEcosystemViz(){
  var svg=document.getElementById('ecosystemSvg');
  var W=560,H=320,cx=160,cy=160,r=130;
  // Zone scores from quiz dimensions
  var dig=scores.digital||0;       // digital relating
  var rel=scores.relational||0;    // relational flexibility
  var emo=scores.emotional||0;     // emotional nurturance
  var erotic=scores.erotic||0;     // erotic/sensual
  var nd=scores.neurodivergence||0;
  var mh=scores.mentalhealth||0;

  // Current distribution (based on scores)
  var aiZone=Math.min(0.95,dig*1.1);
  var digitalHuman=Math.min(0.95,(dig*0.6)+(mh*0.3));
  var inPersonComm=Math.max(0.05,1-dig-rel*0.3);
  var inPersonPart=Math.min(0.9,(rel*0.4)+(emo*0.4));

  // Normalise to sum roughly to 1
  var total=aiZone+digitalHuman+inPersonComm+inPersonPart+0.001;
  aiZone/=total; digitalHuman/=total; inPersonComm/=total; inPersonPart/=total;

  // Ideal distribution nudge (reduce digital, increase human)
  var idealAI=Math.max(0.08,aiZone-0.15);
  var idealDH=Math.max(0.1,digitalHuman-0.1);
  var idealComm=Math.min(0.45,inPersonComm+0.15);
  var idealPart=Math.min(0.45,inPersonPart+0.1);
  var it=idealAI+idealDH+idealComm+idealPart;
  idealAI/=it; idealDH/=it; idealComm/=it; idealPart/=it;

  // Draw pie charts side by side
  function arc(cx,cy,r,start,end,color,opacity){
    var sa=start*Math.PI*2-Math.PI/2;
    var ea=end*Math.PI*2-Math.PI/2;
    var large=end-start>0.5?1:0;
    var x1=cx+Math.cos(sa)*r; var y1=cy+Math.sin(sa)*r;
    var x2=cx+Math.cos(ea)*r; var y2=cy+Math.sin(ea)*r;
    return '<path d="M'+cx+','+cy+' L'+x1.toFixed(1)+','+y1.toFixed(1)+' A'+r+','+r+' 0 '+large+',1 '+x2.toFixed(1)+','+y2.toFixed(1)+' Z" fill="'+color+'" opacity="'+opacity+'"\/>';
  }

  var zones=[
    {label:'AI / Parasocial',color:'#2A4A8A',now:aiZone,ideal:idealAI},
    {label:'Digital Human',color:'#107870',now:digitalHuman,ideal:idealDH},
    {label:'In-Person Community',color:'#906010',now:inPersonComm,ideal:idealComm},
    {label:'Partnered / Intimate',color:'#C04878',now:inPersonPart,ideal:idealPart},
  ];

  var html='';

  // LEFT: Current
  var cumNow=0;
  zones.forEach(function(z){
    html+=arc(cx,cy,r,cumNow,cumNow+z.now,z.color,0.75);
    cumNow+=z.now;
  });
  html+='<circle cx="'+cx+'" cy="'+cy+'" r="38" fill="#F5F0E8"\/>';
  html+='<text x="'+cx+'" y="'+(cy-8)+'" text-anchor="middle" font-size="9" fill="rgba(26,20,16,0.5)" font-family="DM Mono,monospace">NOW<\/text>';
  html+='<text x="'+cx+'" y="'+(cy+8)+'" text-anchor="middle" font-size="8" fill="rgba(26,20,16,0.35)" font-family="DM Mono,monospace">current<\/text>';

  // RIGHT: Ideal
  var rx=390;
  var cumIdeal=0;
  zones.forEach(function(z){
    html+=arc(rx,cy,r,cumIdeal,cumIdeal+z.ideal,z.color,0.45);
    cumIdeal+=z.ideal;
  });
  html+='<circle cx="'+rx+'" cy="'+cy+'" r="38" fill="#F5F0E8"\/>';
  html+='<text x="'+rx+'" y="'+(cy-8)+'" text-anchor="middle" font-size="9" fill="rgba(26,20,16,0.5)" font-family="DM Mono,monospace">IDEAL<\/text>';
  html+='<text x="'+rx+'" y="'+(cy+8)+'" text-anchor="middle" font-size="8" fill="rgba(26,20,16,0.35)" font-family="DM Mono,monospace">direction<\/text>';

  // Legend
  var lx=20,ly=300;
  zones.forEach(function(z,i){
    var lxpos=lx+(i*130);
    html+='<rect x="'+lxpos+'" y="'+(ly-8)+'" width="9" height="9" rx="2" fill="'+z.color+'" opacity="0.7"\/>';
    html+='<text x="'+(lxpos+13)+'" y="'+ly+'" font-size="8" fill="rgba(26,20,16,0.5)" font-family="DM Mono,monospace">'+z.label+'<\/text>';
  });

  // Arrow between charts
  html+='<text x="275" y="166" text-anchor="middle" font-size="18" fill="rgba(26,20,16,0.2)">→<\/text>';

  svg.innerHTML=html;

  // Notes
  var note1=document.getElementById('ecosystemNote1');
  var note2=document.getElementById('ecosystemNote2');

  var biggestNow=zones.reduce(function(a,b){return b.now>a.now?b:a});
  note1.innerHTML='<strong>Right now</strong> — most of your relational energy goes to <strong>'+biggestNow.label+'</strong>. '+
    (dig>0.5?'Your digital relating score suggests AI and online spaces are carrying significant relational weight.':'Your relational energy is relatively distributed.');
  
  var biggestShift=zones.reduce(function(a,b){return (b.ideal-b.now)>(a.ideal-a.now)?b:a});
  note2.innerHTML='<strong>Direction</strong> — the biggest shift that would serve you is more investment in <strong>'+biggestShift.label+'</strong>. '+
    (rel>0.5?'Your relational flexibility suggests openness to multiple forms — use that.':'Starting small with structured, low-stakes human contact is the right entry point.');
}

